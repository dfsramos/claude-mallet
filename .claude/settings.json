{
  "permissions": {
    "allow": [
      "Bash(mariadb*-e*SELECT*)",
      "Bash(mariadb*-e*select*)",
      "Bash(mariadb*-e*SHOW *)",
      "Bash(mariadb*-e*show *)",
      "Bash(mariadb*-e*DESCRIBE *)",
      "Bash(mariadb*-e*describe *)",
      "Bash(mariadb*-e*EXPLAIN *)",
      "Bash(mariadb*-e*explain *)",
      "Bash(mariadb*--execute*SELECT*)",
      "Bash(mariadb*--execute*select*)",
      "Bash(mysql*-e*SELECT*)",
      "Bash(mysql*-e*select*)",
      "Bash(mysql*-e*SHOW *)",
      "Bash(mysql*-e*show *)",
      "Bash(mysql*-e*DESCRIBE *)",
      "Bash(mysql*-e*describe *)",
      "Bash(mysql*-e*EXPLAIN *)",
      "Bash(mysql*-e*explain *)",
      "Bash(mysql*--execute*SELECT*)",
      "Bash(mysql*--execute*select*)",
      "Bash(psql*-c*SELECT*)",
      "Bash(psql*-c*select*)",
      "Bash(psql*-c*SHOW*)",
      "Bash(psql*-c*show*)",
      "Bash(psql*--command*SELECT*)",
      "Bash(psql*--command*select*)",
      "Bash(sqlite3*SELECT*)",
      "Bash(sqlite3*select*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\""
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/user-prompt-submit.sh\""
          }
        ]
      }
    ]
  }
}
